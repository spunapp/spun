# Convex
CONVEX_DEPLOYMENT=your-convex-deployment
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# OpenRouter (AI model access)
OPENROUTER_API_KEY=your-openrouter-api-key

# keypass.id (auth + billing)
# KEYPASS_API_KEY=your-keypass-api-key
# NEXT_PUBLIC_KEYPASS_URL=https://auth.keypass.id

# Meta Ads (optional — Phase 5)
# META_APP_ID=your-meta-app-id
# META_APP_SECRET=your-meta-app-secret
# META_REDIRECT_URI=https://spun.bot/api/integrations/meta/callback

# Google Ads + GA4 (optional — Phase 5)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=https://spun.bot/api/integrations/google/callback

# Klaviyo (optional — Phase 5)
# KLAVIYO_CLIENT_ID=your-klaviyo-client-id
# KLAVIYO_CLIENT_SECRET=your-klaviyo-client-secret
# KLAVIYO_REDIRECT_URI=https://spun.bot/api/integrations/klaviyo/callback
